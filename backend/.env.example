# Copy to `.env` and adjust. These map 1:1 to application*.yml placeholders.
# (Spring does not read .env automatically — export them, or use your IDE /
#  a tool like direnv / dotenv. Kept here as the single source of truth.)

# --- Runtime -----------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local          # local | prod | dev-h2
SERVER_PORT=4000

# --- Database (local / prod) -------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/transitops
DB_USERNAME=transitops
DB_PASSWORD=team@101

# --- JWT ---------------------------------------------------------------------
# Use a long random string in production (>= 32 bytes for HS256).
JWT_SECRET=change-me-in-prod-a-very-long-dev-only-secret-key-1234567890
JWT_EXPIRATION_MS=3600000             # 1 hour
JWT_ISSUER=transitops

# --- CORS --------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
