VITE_APP_NAME=TransitOps

# API base URL. Leave as /api to use the Vite dev-server proxy (same-origin,
# no CORS — works when the frontend is served through ngrok). Set an absolute
# URL only if you want the browser to call the backend directly.
VITE_API_BASE_URL=/api

# Backend origin the dev server proxies /api to (see vite.config.ts).
VITE_PROXY_TARGET=http://localhost:9095
